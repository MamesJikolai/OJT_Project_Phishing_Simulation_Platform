# Copy this to .env and fill in your values: (copy .env.example .env)
# Generate: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=<run: python -c "import secrets; print(secrets.token_hex(50))">
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL — match your psql setup
DB_NAME=phishingopsdatabase
DB_USER=phishingopsuser
DB_PASSWORD=your-password       # change according to user password
DB_HOST=localhost
DB_PORT=5432

# Fernet key for encrypting SMTP passwords in the DB
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=<run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">

# Full URL of this Django server (used to build phishing links)
PLATFORM_BASE_URL=http://127.0.0.1:8000

# Full URL of the React frontend (employees are redirected here after clicking phishing links)
FRONTEND_URL=http://localhost:5173
